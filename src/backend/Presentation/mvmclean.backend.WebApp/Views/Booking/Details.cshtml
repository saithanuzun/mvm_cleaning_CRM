@using mvmclean.backend.Application.Features.Booking.Queries
@model GetBookingByIdResponse

@{
    ViewData["Title"] = "Booking Details";
}

<!-- Page Header Start -->
<div class="page-header container-fluid bg-secondary pt-1 pt-lg-2 pb-1 mb-2">
    <div class="container py-5">
        <div class="row align-items-center py-4">
            <div class="col-md-6 text-center text-md-left">
                <h1 class="mb-4 mb-md-0 text-white">Booking Details - MvM Cleaning Services</h1>
            </div>
            <div class="col-md-6 text-center text-md-right">
                <div class="d-inline-flex align-items-center">
                    <a class="btn text-white" href="/">Home</a>
                    <i class="fas fa-angle-right text-white"></i>
                    <a class="btn text-white" href="/Booking/Find">Find Booking</a>
                    <i class="fas fa-angle-right text-white"></i>
                    <a class="btn text-white disabled" href="">Booking Details</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Booking Details Start -->
<div class="container-fluid py-5 bg-light-alt details-page-bg">
    <div class="container" style="max-width: 950px;">

        <!-- Header Section -->
        <div
            class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 bg-white p-4 rounded-xl shadow-sm border-0 header-card position-relative overflow-hidden">
            <div class="position-absolute header-bg-accent"></div>
            <div class="mb-4 mb-md-0 position-relative z-index-1 flex-grow-1">
                <div class="d-flex align-items-center">
                    <div
                        class="icon-box bg-primary-light rounded-circle p-3 mr-3 d-flex align-items-center justify-content-center">
                        <i class="fas fa-clipboard-check text-primary fa-2x"></i>
                    </div>
                    <div>
                        <h2 class="text-primary font-weight-bold mb-1">Booking Confirmed</h2>
                        <p class="text-muted mb-0" style="font-size: 1.15rem;">Reference: <code
                                class="ref-badge font-weight-bold px-3 py-1 bg-light text-dark rounded-pill shadow-sm">@Model.Id</code>
                        </p>
                    </div>
                </div>
            </div>
            <div class="position-relative z-index-1">
                <a href="/Booking/Find"
                    class="btn btn-outline-primary rounded-pill px-4 py-2 hover-lift font-weight-bold d-inline-flex align-items-center justify-content-center whitespace-nowrap">
                    <i class="fas fa-arrow-left mr-2"></i> Back to Search
                </a>
            </div>
        </div>

        <div class="row">
            <!-- Status & Contact Info Row -->
            <div class="col-lg-4 mb-4">
                <!-- Status Card -->
                <div class="custom-card card border-0 shadow-sm h-100 rounded-xl overflow-hidden">
                    <div class="card-header border-0 pb-0 pt-4 px-4 bg-white d-flex align-items-center">
                        <div class="icon-box-sm bg-primary-light rounded-circle p-2 mr-3 d-flex align-items-center justify-content-center"
                            style="width: 40px; height: 40px;">
                            <i class="fas fa-info-circle text-primary"></i>
                        </div>
                        <h5 class="mb-0 text-dark font-weight-bold">Status</h5>
                    </div>
                    <div
                        class="card-body px-4 pb-4 pt-3 d-flex flex-column align-items-center justify-content-center text-center">
                        <div class="status-badge-container mb-3 mt-2">
                            @{
                                var statusClass = "bg-primary";
                                if (Model.Status.ToString().ToLowerInvariant() == "completed") { statusClass = "bg-success"; }
                                else if (Model.Status.ToString().ToLowerInvariant() == "cancelled") { statusClass = "bg-danger"; }
                                else if (Model.Status.ToString().ToLowerInvariant() == "pending") { statusClass = "bg-warning text-dark"; }
                            }
                            <span
                                class="badge @statusClass rounded-pill px-4 py-2 shadow-sm font-weight-bold d-inline-flex align-items-center"
                                style="font-size: 1.1rem;">
                                @if (Model.Status.ToString().ToLowerInvariant() == "completed")
                                {
                                    <i class="fas fa-check-circle mr-2"></i>
                                }
                                else
                                {
                                    <i class="fas fa-circle mr-2" style="font-size: 0.8rem; opacity: 0.8"></i>
                                }
                                @Model.Status
                            </span>
                        </div>
                        <p class="text-muted mb-0 font-weight-medium">
                            Created: <span class="text-dark">@Model.CreatedAt.ToString("dd MMM yyyy")</span>
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-lg-8 mb-4">
                <!-- Contact Card -->
                <div class="custom-card card border-0 shadow-sm h-100 rounded-xl overflow-hidden">
                    <div class="card-header border-0 pb-0 pt-4 px-4 bg-white d-flex align-items-center">
                        <div class="icon-box-sm bg-primary-light rounded-circle p-2 mr-3 d-flex align-items-center justify-content-center"
                            style="width: 40px; height: 40px;">
                            <i class="fas fa-user text-primary"></i>
                        </div>
                        <h5 class="mb-0 text-dark font-weight-bold">Contact Details</h5>
                    </div>
                    <div class="card-body p-4">
                        <div class="row">
                            @if (Model.Customer != null && !string.IsNullOrEmpty(Model.Customer.FullName))
                            {
                                <div class="col-md-6 mb-4">
                                    <div class="d-flex align-items-start">
                                        <i class="fas fa-id-card text-muted mr-3 mt-1 fs-5"></i>
                                        <div>
                                            <label
                                                class="text-muted small text-uppercase font-weight-bold letter-spacing-1 mb-1 d-block">Customer
                                                Name</label>
                                            <p class="mb-0 font-weight-medium text-dark" style="font-size: 1.1rem;">
                                                @Model.Customer.FullName</p>
                                        </div>
                                    </div>
                                </div>
                            }
                            <div class="col-md-6 mb-4">
                                <div class="d-flex align-items-start">
                                    <i class="fas fa-phone-alt text-muted mr-3 mt-1 fs-5"></i>
                                    <div>
                                        <label
                                            class="text-muted small text-uppercase font-weight-bold letter-spacing-1 mb-1 d-block">Phone
                                            Number</label>
                                        <p class="mb-0 font-weight-medium text-dark" style="font-size: 1.1rem;">
                                            @Model.PhoneNumber</p>
                                    </div>
                                </div>
                            </div>
                            @if (Model.Customer != null)
                            {
                                <div class="col-md-6 mb-4 mb-md-0">
                                    <div class="d-flex align-items-start">
                                        <i class="fas fa-envelope text-muted mr-3 mt-1 fs-5"></i>
                                        <div>
                                            <label
                                                class="text-muted small text-uppercase font-weight-bold letter-spacing-1 mb-1 d-block">Email
                                                Address</label>
                                            <p class="mb-0 font-weight-medium text-dark" style="font-size: 1.1rem;">
                                                @if (string.IsNullOrEmpty(Model.Customer.Email))
                                                {
                                                    <span class="text-muted font-italic">Not provided</span>
                                                }
                                                else
                                                {
                                                    @Model.Customer.Email
                                                }
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            }
                            <div class="col-md-6">
                                <div class="d-flex align-items-start">
                                    <i class="fas fa-map-marked-alt text-muted mr-3 mt-1 fs-5"></i>
                                    <div>
                                        <label
                                            class="text-muted small text-uppercase font-weight-bold letter-spacing-1 mb-1 d-block">Postcode</label>
                                        <p class="mb-0 font-weight-medium text-dark" style="font-size: 1.1rem;">
                                            @Model.Postcode</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Service Info Row -->
            @if (Model.ServiceAddress != null)
            {
                <div class="col-lg-6 mb-4">
                    <!-- Address Card -->
                    <div
                        class="custom-card card border-0 shadow-sm h-100 rounded-xl overflow-hidden address-card position-relative">
                        <div class="card-bg-icon"><i class="fas fa-home"></i></div>
                        <div
                            class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex align-items-center position-relative z-index-1">
                            <div class="icon-box-sm bg-white shadow-sm rounded-circle p-2 mr-3 d-flex align-items-center justify-content-center"
                                style="width: 40px; height: 40px;">
                                <i class="fas fa-map-marker-alt text-primary"></i>
                            </div>
                            <h5 class="mb-0 text-white font-weight-bold">Service Location</h5>
                        </div>
                        <div class="card-body p-4 position-relative z-index-1 text-white">
                            <div class="address-content bg-white bg-opacity-10 backdrop-blur rounded-lg p-3 mt-2 border border-white border-opacity-25"
                                style="border-color: rgba(255,255,255,0.2) !important; background-color: rgba(255,255,255,0.1) !important;">
                                <h4 class="font-weight-bold mb-1 text-white">@Model.ServiceAddress.Street</h4>
                                <h5 class="mb-0 text-white opacity-90">@Model.ServiceAddress.City</h5>
                            </div>
                            <p class="mt-3 mb-0 opacity-75 d-flex align-items-center">
                                <i class="fas fa-info-circle mr-2"></i> Our team will arrive at this location.
                            </p>
                        </div>
                    </div>
                </div>
            }

            @if (Model.ScheduledSlot != null)
            {
                <div class="col-lg-6 mb-4">
                    <!-- Schedule Card -->
                    <div
                        class="custom-card card border-0 shadow-sm h-100 rounded-xl overflow-hidden schedule-card position-relative">
                        <div class="card-bg-icon"><i class="fas fa-calendar-alt"></i></div>
                        <div
                            class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex align-items-center position-relative z-index-1">
                            <div class="icon-box-sm bg-white shadow-sm rounded-circle p-2 mr-3 d-flex align-items-center justify-content-center"
                                style="width: 40px; height: 40px;">
                                <i class="fas fa-clock text-secondary" style="color: #46C6CE !important;"></i>
                            </div>
                            <h5 class="mb-0 text-white font-weight-bold">Scheduled Time</h5>
                        </div>
                        <div class="card-body p-4 position-relative z-index-1">
                            <div class="schedule-timeline mt-2 ml-1">
                                <div class="timeline-item d-flex mb-4">
                                    <div class="timeline-icon bg-white text-secondary shadow-sm rounded-circle d-flex align-items-center justify-content-center font-weight-bold mr-3 position-relative z-index-1"
                                        style="width: 36px; height: 36px; min-width: 36px; color: #46C6CE !important;">
                                        <i class="fas fa-play" style="font-size: 0.8rem; padding-left: 2px;"></i>
                                    </div>
                                    <div class="timeline-content text-white">
                                        <p class="small text-uppercase font-weight-bold letter-spacing-1 mb-1 opacity-75">
                                            Arrival Window Starts</p>
                                        <h5 class="font-weight-bold mb-0 text-white">
                                            @Model.ScheduledSlot.StartTime.ToString("dd MMM yyyy - HH:mm")</h5>
                                    </div>
                                </div>
                                <div class="timeline-line"></div>
                                <div class="timeline-item d-flex">
                                    <div class="timeline-icon bg-white text-secondary shadow-sm rounded-circle d-flex align-items-center justify-content-center font-weight-bold mr-3 position-relative z-index-1"
                                        style="width: 36px; height: 36px; min-width: 36px; color: #46C6CE !important;">
                                        <i class="fas fa-stop" style="font-size: 0.8rem;"></i>
                                    </div>
                                    <div class="timeline-content text-white pt-1">
                                        <p class="small text-uppercase font-weight-bold letter-spacing-1 mb-1 opacity-75">
                                            Estimated Completion</p>
                                        <h5 class="font-weight-bold mb-0 text-white">
                                            @Model.ScheduledSlot.EndTime.ToString("dd MMM yyyy - HH:mm")</h5>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Payment Card -->
            <div class="col-12 mb-5">
                <div class="custom-card card border-0 shadow-sm rounded-xl overflow-hidden">
                    <div class="card-body p-0">
                        <div class="row">
                            <div class="col-md-7 p-4 p-md-5 d-flex flex-column justify-content-center bg-white">
                                <div class="d-flex align-items-center mb-3">
                                    <div class="icon-box-sm bg-primary-light rounded-circle p-2 mr-3 d-flex align-items-center justify-content-center"
                                        style="width: 48px; height: 48px;">
                                        <i class="fas fa-file-invoice-dollar text-primary fa-lg"></i>
                                    </div>
                                    <h4 class="mb-0 text-dark font-weight-bold">Payment Summary</h4>
                                </div>
                                <p class="text-muted mb-0" style="font-size: 1.1rem;">
                                    This is the total amount for your scheduled cleaning service. It includes all
                                    selected rooms, items, and any additional requests.
                                </p>
                            </div>
                            <div
                                class="col-md-5 bg-light p-4 p-md-5 d-flex flex-column justify-content-center align-items-center text-center border-left-md">
                                <p class="text-uppercase text-muted font-weight-bold letter-spacing-1 mb-2">Total Amount
                                </p>
                                <h1 class="display-4 text-primary font-weight-bold mb-0">
                                    £@Model.TotalPrice.ToString("0.00")</h1>
                                <span
                                    class="badge bg-success-light text-success rounded-pill mt-3 px-3 py-1 font-weight-bold border-success">
                                    <i class="fas fa-shield-alt mr-1"></i> Secure Booking
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="col-12">
                <div class="row justify-content-center">
                    <div class="col-md-5 mb-3 mb-md-0">
                        <a href="/Booking/Find"
                            class="btn btn-outline-primary btn-lg w-100 rounded-pill py-3 font-weight-bold shadow-sm hover-lift d-flex align-items-center justify-content-center transition-all background-white">
                            <i class="fas fa-search mr-2"></i> Find Another Booking
                        </a>
                    </div>
                    <div class="col-md-5">
                        <a href="tel:07405392635"
                            class="btn btn-primary btn-gradient btn-lg w-100 rounded-pill py-3 font-weight-bold shadow-lg hover-lift d-flex align-items-center justify-content-center transition-all position-relative overflow-hidden">
                            <span class="position-relative z-index-1">
                                <i class="fas fa-phone-alt mr-2"></i> Support: 07405 392 635
                            </span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Help Section -->
            <div class="col-12 mt-5">
                <div
                    class="help-card bg-white rounded-xl p-4 p-md-5 shadow-sm border border-light transition-all d-flex flex-column flex-md-row align-items-center">
                    <div class="icon-container mr-md-4 mb-4 mb-md-0 bg-light rounded-circle d-flex justify-content-center align-items-center"
                        style="width: 80px; height: 80px; min-width: 80px;">
                        <i class="fas fa-headset fa-2x text-primary"></i>
                    </div>
                    <div class="flex-grow-1 text-center text-md-left">
                        <h4 class="text-dark font-weight-bold mb-2">Need to make changes?</h4>
                        <p class="text-muted mb-3" style="font-size: 1.1rem;">We're here to help. Contact our team if
                            you have any questions or need to modify your schedule.</p>
                        <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-md-start">
                            <a href="mailto:info@mvmcleaning.com"
                                class="text-primary font-weight-bold d-inline-flex align-items-center text-decoration-none hover-text-secondary transition-all mb-2 mb-sm-0 mr-sm-4">
                                <i class="fas fa-envelope mr-2 bg-primary-light p-2 rounded-circle"></i>
                                info@mvmcleaning.com
                            </a>
                            <a href="tel:07405392635"
                                class="text-primary font-weight-bold d-inline-flex align-items-center text-decoration-none hover-text-secondary transition-all mt-2 mt-sm-0">
                                <i class="fas fa-phone mr-2 bg-primary-light p-2 rounded-circle"></i> 07405 392 635
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<!-- Booking Details End -->

<style>
    /* Custom Styles for Details Page */
    .bg-light-alt {
        background-color: #f8f9fa;
    }

    .rounded-xl {
        border-radius: 1.25rem !important;
    }

    .rounded-lg {
        border-radius: 0.75rem !important;
    }

    .rounded-pill {
        border-radius: 50rem !important;
    }

    .letter-spacing-1 {
        letter-spacing: 1px;
    }

    .z-index-1 {
        z-index: 1;
    }

    .opacity-90 {
        opacity: 0.9;
    }

    .opacity-75 {
        opacity: 0.75;
    }

    .backdrop-blur {
        backdrop-filter: blur(5px);
        -webkit-backdrop-filter: blur(5px);
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .whitespace-nowrap {
        white-space: nowrap;
    }

    .hover-lift {
        transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .hover-lift:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1) !important;
    }

    .hover-text-secondary:hover {
        color: #46C6CE !important;
    }

    /* Utilities & Colors */
    .bg-primary-light {
        background-color: rgba(25, 67, 118, 0.1);
    }

    .bg-success-light {
        background-color: rgba(25, 135, 84, 0.1);
        border: 1px solid rgba(25, 135, 84, 0.3);
    }

    /* Cards */
    .custom-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .custom-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08) !important;
    }

    /* Header Card */
    .header-card {
        border: 1px solid rgba(0, 0, 0, 0.03) !important;
    }

    .header-bg-accent {
        top: 0;
        left: 0;
        bottom: 0;
        width: 6px;
        background: linear-gradient(to bottom, #194376, #46C6CE);
        border-top-left-radius: 1.25rem;
        border-bottom-left-radius: 1.25rem;
    }

    .ref-badge {
        font-family: monospace;
        letter-spacing: 1px;
        border: 1px solid rgba(0, 0, 0, 0.1);
        font-size: 1rem;
    }

    /* Address & Schedule Themed Cards */
    .address-card {
        background: linear-gradient(135deg, #194376 0%, #112d4f 100%);
        color: white;
    }

    .schedule-card {
        background: linear-gradient(135deg, #46C6CE 0%, #2b9aa2 100%);
        color: white;
    }

    .card-bg-icon {
        position: absolute;
        right: -20px;
        bottom: -20px;
        font-size: 8rem;
        opacity: 0.1;
        transform: rotate(-15deg);
        z-index: 0;
        pointer-events: none;
    }

    /* Timeline styling for Schedule Card */
    .schedule-timeline {
        position: relative;
    }

    .timeline-line {
        position: absolute;
        left: 17px;
        top: 36px;
        bottom: 12px;
        width: 2px;
        background-color: rgba(255, 255, 255, 0.3);
        margin-left: -1px;
        z-index: 0;
    }

    /* Border utility for payment card */
    @@media (min-width: 768px) {
        .border-left-md {
            border-left: 1px solid rgba(0, 0, 0, 0.05);
        }
    }

    /* Buttons */
    .btn-gradient {
        background: linear-gradient(135deg, #194376 0%, #2d5fa3 100%);
        border: none;
        color: white;
        z-index: 1;
    }

    .btn-gradient::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 50rem;
        background: linear-gradient(135deg, #2d5fa3 0%, #194376 100%);
        opacity: 0;
        z-index: -1;
        transition: opacity 0.4s ease;
    }

    .btn-gradient:hover::before {
        opacity: 1;
    }

    .btn-outline-primary {
        color: #194376;
        border-color: #194376;
        border-width: 2px;
    }

    .btn-outline-primary:hover {
        background-color: #194376;
        color: white;
    }

    .background-white {
        background-color: white;
    }
</style>