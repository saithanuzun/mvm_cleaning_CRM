@{
    ViewData["Title"] = "Find Your Booking";
}

<!-- Page Header Start -->
<div class="page-header container-fluid bg-secondary pt-1 pt-lg-2 pb-1 mb-2">
    <div class="container py-5">
        <div class="row align-items-center py-4">
            <div class="col-md-6 text-center text-md-left">
                <h1 class="mb-4 mb-md-0 text-white">Find Your Booking - MvM Cleaning Services</h1>
            </div>
            <div class="col-md-6 text-center text-md-right">
                <div class="d-inline-flex align-items-center">
                    <a class="btn text-white" href="/">Home</a>
                    <i class="fas fa-angle-right text-white"></i>
                    <a class="btn text-white disabled" href="">Find Booking</a>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Find Booking Start -->
<div class="container-fluid py-5">
    <div class="container" style="max-width: 900px;">
        <div class="row">
            <div class="col-12">
                <div class="row mb-5">
                    <div class="col-md-4">
                        <div
                            class="feature-card d-flex flex-column align-items-center justify-content-center text-center p-4 rounded-lg shadow-sm bg-white mb-4 h-100">
                            <div class="icon-circle d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 transition-all"
                                style="width: 80px; height: 80px;">
                                <i class="fa fa-search fa-2x text-primary transition-all"></i>
                            </div>
                            <h5 class="font-weight-bold m-0 mt-2 text-primary">Quick Search</h5>
                            <p class="text-muted mb-0 mt-2 text-center">Find your booking in seconds</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="feature-card d-flex flex-column align-items-center justify-content-center text-center p-4 rounded-lg shadow-sm bg-white mb-4 h-100">
                            <div class="icon-circle d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 transition-all"
                                style="width: 80px; height: 80px;">
                                <i class="fa fa-phone-alt fa-2x text-primary transition-all"></i>
                            </div>
                            <h5 class="font-weight-bold m-0 mt-2 text-primary">Phone & Postcode</h5>
                            <p class="text-muted mb-0 mt-2 text-center">Two details needed</p>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div
                            class="feature-card d-flex flex-column align-items-center justify-content-center text-center p-4 rounded-lg shadow-sm bg-white mb-4 h-100">
                            <div class="icon-circle d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3 transition-all"
                                style="width: 80px; height: 80px;">
                                <i class="fa fa-shield-alt fa-2x text-primary transition-all"></i>
                            </div>
                            <h5 class="font-weight-bold m-0 mt-2 text-primary">Secure & Private</h5>
                            <p class="text-muted mb-0 mt-2 text-center">Your data is protected</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-12">
                <div class="contact-form bg-white p-5 rounded-lg shadow-lg border-0">
                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger alert-dismissible fade show rounded-lg custom-alert shadow-sm border-0"
                            role="alert">
                            <div class="d-flex align-items-center mb-2">
                                <i class="fas fa-exclamation-circle fs-5 mr-2"></i>
                                <h6 class="mb-0 font-weight-bold">Please correct the following errors:</h6>
                            </div>
                            <ul class="mb-0 mt-2 pl-4">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show rounded-lg custom-alert shadow-sm border-0 d-flex align-items-center"
                            role="alert">
                            <i class="fas fa-check-circle fs-5 mr-2"></i>
                            <div>@TempData["SuccessMessage"]</div>
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="text-center mb-5">
                        <div class="d-inline-flex align-items-center justify-content-center bg-primary rounded-circle mb-3"
                            style="width: 60px; height: 60px;">
                            <i class="fas fa-search text-white" style="font-size: 1.5rem;"></i>
                        </div>
                        <h2 class="text-primary font-weight-bold mb-3">Find Your Booking</h2>
                        <p class="text-muted" style="font-size: 1.15rem;">Enter your phone number and postcode to
                            securely access your booking details.</p>
                    </div>

                    <form method="post" asp-action="Find" asp-controller="Booking" class="custom-form">
                        @Html.AntiForgeryToken()

                        <div class="form-row">
                            <div class="col-md-6 mb-4">
                                <div class="form-group mb-0">
                                    <label for="phoneNumber" class="form-label font-weight-bold text-dark">Telephone
                                        Number <span class="text-danger">*</span></label>
                                    <div
                                        class="input-group input-group-lg shadow-sm rounded-lg overflow-hidden custom-input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-white border-right-0 text-primary">
                                                <i class="fas fa-phone-alt"></i>
                                            </span>
                                        </div>
                                        <input type="tel" class="form-control border-left-0 pl-0 custom-input pl-2"
                                            id="phoneNumber" name="phoneNumber" placeholder="e.g. 07405 392 635"
                                            required
                                            value="@(ViewData.ModelState["phoneNumber"]?.AttemptedValue ?? "")">
                                    </div>
                                    <small class="form-text text-muted mt-2">
                                        <i class="fas fa-info-circle mr-1"></i> The number used when creating the
                                        booking
                                    </small>
                                </div>
                            </div>
                            <div class="col-md-6 mb-4">
                                <div class="form-group mb-0">
                                    <label for="postcode" class="form-label font-weight-bold text-dark">Postcode <span
                                            class="text-danger">*</span></label>
                                    <div
                                        class="input-group input-group-lg shadow-sm rounded-lg overflow-hidden custom-input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-white border-right-0 text-primary">
                                                <i class="fas fa-map-marker-alt"></i>
                                            </span>
                                        </div>
                                        <input type="text"
                                            class="form-control border-left-0 pl-0 text-uppercase custom-input pl-2"
                                            id="postcode" name="postcode" placeholder="e.g. SW1A 1AA" required
                                            value="@(ViewData.ModelState["postcode"]?.AttemptedValue ?? "")">
                                    </div>
                                    <small class="form-text text-muted mt-2">
                                        <i class="fas fa-info-circle mr-1"></i> The postcode for the service address
                                    </small>
                                </div>
                            </div>
                        </div>

                        <div class="form-group text-center mt-5">
                            <button type="submit"
                                class="btn btn-primary btn-lg btn-gradient px-5 py-3 shadow-lg rounded-pill font-weight-bold d-inline-flex align-items-center justify-content-center position-relative overflow-hidden w-100"
                                style="max-width: 300px;">
                                <span class="position-relative z-index-1">
                                    <i class="fas fa-search mr-2"></i> Find My Booking
                                </span>
                            </button>
                        </div>
                    </form>

                    <div class="mt-5 pt-5 border-top border-light">
                        <div
                            class="help-card bg-light rounded-lg p-4 d-flex flex-column flex-md-row align-items-center justify-content-between transition-all">
                            <div class="mb-3 mb-md-0 text-center text-md-left">
                                <h5 class="text-primary font-weight-bold mb-1">Need Help?</h5>
                                <p class="text-muted mb-0">Our support team is ready to assist you.</p>
                            </div>
                            <div class="d-flex flex-column flex-sm-row text-center text-md-right align-items-center">
                                <a href="tel:07405392635"
                                    class="btn btn-white shadow-sm rounded-pill text-primary font-weight-bold px-4 py-2 border-0 hover-lift mb-2 mb-sm-0 mx-2">
                                    <i class="fas fa-phone-alt mr-2"></i> 07405 392 635
                                </a>
                                <a href="mailto:info@mvmcleaning.com"
                                    class="btn btn-white shadow-sm rounded-pill text-primary font-weight-bold px-4 py-2 border-0 hover-lift mx-2">
                                    <i class="fas fa-envelope mr-2"></i> Email Support
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Find Booking End -->

<style>
    /* Custom Styles for Find Booking Page */
    .rounded-lg {
        border-radius: 1rem !important;
    }

    .rounded-pill {
        border-radius: 50rem !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }

    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .15) !important;
    }

    /* Feature Cards */
    .feature-card {
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .feature-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1) !important;
        border-color: rgba(25, 67, 118, 0.1);
    }

    .feature-card:hover .icon-circle {
        background-color: #194376 !important;
        transform: scale(1.1);
    }

    .feature-card:hover .icon-circle i {
        color: white !important;
    }

    /* Form Enhancements */
    .custom-input-group {
        border: 2px solid #e9ecef;
        transition: all 0.3s ease;
        background: #fff;
    }

    .custom-input-group:focus-within {
        border-color: #46C6CE;
        box-shadow: 0 0 0 0.25rem rgba(70, 198, 206, 0.25) !important;
    }

    .custom-input-group .input-group-text {
        border: none;
        background: transparent;
    }

    .custom-input {
        border: none;
        background: transparent;
        font-weight: 500;
        color: #333;
    }

    .custom-input:focus {
        box-shadow: none;
        background: transparent;
    }

    .custom-input::placeholder {
        color: #adb5bd;
        font-weight: 400;
    }

    /* Gradient Button */
    .btn-gradient {
        background: linear-gradient(135deg, #194376 0%, #2d5fa3 100%);
        border: none;
        color: white;
        transition: all 0.4s ease;
        z-index: 1;
    }

    .btn-gradient::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        border-radius: 50rem;
        background: linear-gradient(135deg, #2d5fa3 0%, #194376 100%);
        opacity: 0;
        z-index: -1;
        transition: opacity 0.4s ease;
    }

    .btn-gradient:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(25, 67, 118, 0.3) !important;
        color: white;
    }

    .btn-gradient:hover::before {
        opacity: 1;
    }

    /* Alerts & Help Card */
    .custom-alert {
        border-left: 5px solid;
    }

    .alert-danger.custom-alert {
        border-left-color: #dc3545;
        background-color: #fff8f8;
        color: #842029;
    }

    .alert-success.custom-alert {
        border-left-color: #198754;
        background-color: #f3fcf7;
        color: #0f5132;
    }

    .help-card {
        border: 1px solid rgba(0, 0, 0, 0.05);
    }

    .help-card:hover {
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .08) !important;
        background-color: white !important;
    }

    .btn-white {
        background-color: white;
        color: #194376;
    }

    .btn-white:hover {
        color: #2d5fa3;
    }

    .z-index-1 {
        z-index: 1;
    }
</style>

@section Scripts {
    <script>
        // Auto-format postcode to uppercase
        document.getElementById('postcode')?.addEventListener('input', function (e) {
            this.value = this.value.toUpperCase();
        });

        // Auto-format phone number (basic example)
        document.getElementById('phoneNumber')?.addEventListener('input', function (e) {
            let value = this.value.replace(/\D/g, '');
            if (value.length > 0) {
                if (value.startsWith('0')) {
                    if (value.length <= 4) {
                        this.value = value;
                    } else if (value.length <= 7) {
                        this.value = value.slice(0, 4) + ' ' + value.slice(4);
                    } else {
                        this.value = value.slice(0, 4) + ' ' + value.slice(4, 7) + ' ' + value.slice(7, 11);
                    }
                }
            }
        });
    </script>
}