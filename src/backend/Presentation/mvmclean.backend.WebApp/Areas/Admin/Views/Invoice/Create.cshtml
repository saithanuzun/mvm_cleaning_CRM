<form method="post" action="@Url.Action("Generate", "Invoice", new { area = "Admin" })">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label for="ClientName" class="form-label">Client Name *</label>
        <input type="text" 
               id="ClientName" 
               name="ClientName" 
               class="form-control" 
               value="@Model?.ClientName" />
    </div>

    <div class="mb-3">
        <label for="ClientAddress" class="form-label">Client Address *</label>
        <textarea id="ClientAddress" 
                  name="ClientAddress"  
                  class="form-control" 
                  rows="3">@Model?.ClientAddress</textarea>
    </div>

    <div class="mb-3">
        <label for="Description" class="form-label">Service Description *</label>
        <textarea id="Description" 
                  name="Description"  
                  class="form-control" 
                  rows="3">@Model?.Description</textarea>
    </div>

    <div class="mb-3">
        <label for="Amount" class="form-label">Amount (£) *</label>
        <input type="number" 
               id="Amount" 
               name="Amount"  
               step="0.01" 
               class="form-control" 
               value="@Model?.Amount" />
    </div>

    <div class="mb-3">
        <label for="PaymentDue" class="form-label">Payment Terms</label>
        <select id="PaymentDue" 
                name="PaymentDue" 
                class="form-select">
            <option value="-1">Due on Receipt</option>
            <option value="0">Already Paid</option>
            <option value="7">Due in 7 days</option>
            <option value="14">Due in 14 days</option>
            <option value="30">Due in 30 days</option>
        </select>
    </div>

    <div class="mb-4">
        <label for="DateTime" class="form-label">Invoice Date</label>
        <input type="datetime-local" 
               id="DateTime" 
               name="DateTime"  
               class="form-control" 
               value="@Model?.DateTime.ToString("yyyy-MM-ddTHH:mm")" />
    </div>

    <button type="submit" class="btn btn-primary">Generate Invoice</button>
</form>